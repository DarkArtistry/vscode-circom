{
  "name": "circom-lang",
  "displayName": "Circom Language Support",
  "description": "Syntax highlighting, snippets, and language support for Circom 2.x zero-knowledge circuit language",
  "version": "0.2.0",
  "publisher": "darkartistry",
  "author": {
    "name": "darkartistry"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/darkartistry/vscode-circom"
  },
  "bugs": {
    "url": "https://github.com/darkartistry/vscode-circom/issues"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:circom"
  ],
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "circom",
    "zero-knowledge",
    "zk-snark",
    "circuit",
    "groth16",
    "plonk",
    "snarkjs"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "contributes": {
    "languages": [
      {
        "id": "circom",
        "aliases": [
          "Circom",
          "circom"
        ],
        "extensions": [
          ".circom"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "circom",
        "scopeName": "source.circom",
        "path": "./syntaxes/circom.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "circom",
        "path": "./snippets/circom.json"
      }
    ],
    "iconThemes": [
      {
        "id": "circom-icons",
        "label": "Circom File Icons",
        "path": "./fileicons/circom-icon-theme.json"
      }
    ],
    "configuration": {
      "title": "Circom",
      "properties": {
        "circom.includePaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional paths to search for Circom include files"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:min": "node esbuild.mjs --minify",
    "watch": "node esbuild.mjs --watch"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
